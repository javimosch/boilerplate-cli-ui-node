{
  "name": "boilerplate-cli-ui-node",
  "version": "1.0.0",
  "description": "A generic CLI+WebUI boilerplate following modular design principles",
  "main": "src/cli.js",
  "bin": {
    "boilerplate-cli-ui-node": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "ui": "node src/cli.js --ui",
    "web": "cd interfaces/webui && npm start",
    "dev": "nodemon src/cli.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "node build.js"
  },
  "keywords": [
    "cli",
    "webui",
    "boilerplate",
    "modular"
  ],
  "author": "CLI+WebUI Boilerplate",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "nodemon": "^3.0.1"
  }
}
